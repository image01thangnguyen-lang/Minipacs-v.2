  status            String
  reason            String?
  createdAt         DateTime @default(now())

  run RetentionRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([studyInstanceUid])
  @@index([status])
  @@map("retention_run_items")
}

model BackupJob {
  id             String    @id @default(uuid())
  jobType        String    // STORAGE_TEST | BACKUP_RUN | RESTORE_CHECKLIST | VERIFY_BACKUP
  status         String    // PENDING | RUNNING | SUCCESS | FAILED | CANCELLED
  sourceFolderId String?
  targetFolderId String?
  startedByUserId String?
  progress       Int       @default(0)
  fileCount      Int       @default(0)
  totalBytes     BigInt    @default(0)
  copiedBytes    BigInt    @default(0)
  errorMessage   String?   @db.Text
  summaryJson    String?   @db.Text
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([jobType])
  @@index([status])
  @@index([createdAt])
  @@map("backup_jobs")
}

model DestructiveOperationRequest {
  id                   String    @id @default(uuid())
  operationType        String    // DELETE_STUDY | DELETE_SERIES | DELETE_NON_DICOM_MEDIA | PURGE_EXPORT_JOB | RETENTION_EXECUTE
  status               String    // REQUESTED | DRY_RUN_READY | APPROVED | REJECTED | EXECUTING | COMPLETED | FAILED | CANCELLED
  entityType           String
  entityId             String?
  studyInstanceUid     String?
  seriesInstanceUid    String?
  nonDicomMediaId      String?
  reason               String    @db.Text
  confirmationPhrase   String?
  requestedByUserId    String?
  approvedByUserId     String?
  executedByUserId     String?
  dryRunJson           String?   @db.Text
  impactSummaryJson    String?   @db.Text
  errorMessage         String?   @db.Text
  createdAt            DateTime  @default(now())
  approvedAt           DateTime?
  executedAt           DateTime?
  updatedAt            DateTime  @updatedAt

  @@index([status])
  @@index([operationType])
  @@index([entityType, entityId])
  @@index([studyInstanceUid])
  @@index([createdAt])
  @@map("destructive_operation_requests")
}
