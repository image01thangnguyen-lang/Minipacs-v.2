  sharedSecret       String?
  allowedActionsJson String?   @db.Text
  lastHealthStatus   String?
  lastHealthAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("native_connector_configs")
}

model NativeConnectorEvent {
  id           String   @id @default(uuid())
  actionKey    String
  status       String
  actorUserId  String?
  actorUser    User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  targetType   String?
  targetId     String?
  message      String?  @db.Text
  metadataJson String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([actionKey])
  @@index([status])
  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("native_connector_events")
}

// ==========================================
// PHASE 10: Release, UAT, Operations Handoff
// ==========================================

model ReleaseCandidate {
  id                String    @id @default(uuid())
  version           String    @unique
  title             String    @default("")
  targetEnvironment String    @default("STAGING")
  status            String // DRAFT | TESTING | BLOCKED | READY_FOR_SIGNOFF | APPROVED | RELEASED | ROLLED_BACK
  notes             String?   @db.Text
  releaseNotes      String?   @db.Text
  rollbackPlan      String?   @db.Text
  gitCommit         String?
  imageTag          String?
  buildChecksum     String?
  migrationStatus   String    @default("UNKNOWN") // UNKNOWN | PENDING | APPLIED | FAILED
  seedStatus        String    @default("UNKNOWN") // UNKNOWN | PENDING | APPLIED | FAILED
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  releasedAt        DateTime?
  lockedAt          DateTime?
  createdByUserId   String?
  createdByUser     User?     @relation("ReleaseCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lockedByUserId    String?
  lockedByUser      User?     @relation("ReleaseLockedBy", fields: [lockedByUserId], references: [id], onDelete: SetNull)
  uatSuiteId        String?
  uatSuite          UatSuite? @relation(fields: [uatSuiteId], references: [id], onDelete: SetNull)

  signOffs       ReleaseSignOff[]
  knownIssues    ReleaseKnownIssue[]
  changeRequests ChangeRequest[]
  handoff        ReleaseHandoffRecord?

  @@index([status])
  @@index([createdAt])
  @@index([uatSuiteId])
  @@map("release_candidates")
}

model ReleaseSignOff {
  id             String           @id @default(uuid())
  releaseId      String
  release        ReleaseCandidate @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  role           String
  status         String // PENDING | APPROVED | REJECTED
  notes          String?          @db.Text
  evidenceUrl    String?
  readinessJson  String?          @db.Text
  attested       Boolean          @default(false)
  signedByUserId String?
  signedByUser   User?            @relation(fields: [signedByUserId], references: [id], onDelete: SetNull)
  signedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([releaseId, role])
  @@index([releaseId])
  @@map("release_signoffs")
}

model ReleaseKnownIssue {
  id               String           @id @default(uuid())
  releaseId        String
  release          ReleaseCandidate @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  ticketId         String?
  description      String           @db.Text
  riskLevel        String // LOW | MEDIUM | HIGH
  workaround       String?          @db.Text
  status           String           @default("OPEN") // OPEN | ACCEPTED | RESOLVED
  acceptanceNotes  String?          @db.Text
  acceptedByUserId String?
  acceptedByUser   User?            @relation("ReleaseKnownIssueAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  acceptedAt       DateTime?
  createdAt        DateTime         @default(now())

  @@index([releaseId])
  @@index([status])
  @@map("release_known_issues")
}

model ReleaseHandoffRecord {
  id                   String           @id @default(uuid())
  releaseId            String           @unique
  release              ReleaseCandidate @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  status               String           @default("DRAFT") // DRAFT | READY | ACCEPTED
  buildPassed          Boolean          @default(false)
  typecheckPassed      Boolean          @default(false)
  prismaValidated      Boolean          @default(false)
  migrationReviewed    Boolean          @default(false)
  seedVerified         Boolean          @default(false)
  manualSmokeCompleted Boolean          @default(false)
  docsUpdated          Boolean          @default(false)
  rollbackReviewed     Boolean          @default(false)
  monitoringReviewed   Boolean          @default(false)
  noPhiAttested        Boolean          @default(false)
  qaSummary            String?          @db.Text
  handoffSummary       String?          @db.Text
  operationsOwner      String?
  supportContact       String?
  rollbackOwner        String?
  preparedByUserId     String?
  preparedByUser       User?            @relation("ReleaseHandoffPreparedBy", fields: [preparedByUserId], references: [id], onDelete: SetNull)
  preparedAt           DateTime?
  acceptedByUserId     String?
  acceptedByUser       User?            @relation("ReleaseHandoffAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)
  acceptedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([status])
  @@map("release_handoff_records")
}

model UatSuite {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  version     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases             UatCase[]
  runs              UatRun[]
  changeRequests    ChangeRequest[]
  releaseCandidates ReleaseCandidate[]

  @@map("uat_suites")
}

model UatCase {
  id          String   @id @default(uuid())
  suiteId     String
  suite       UatSuite @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  category    String?
  title       String
  description String   @db.Text
  steps       String   @db.Text
  expected    String   @db.Text
  isCritical  Boolean  @default(false)
  createdAt   DateTime @default(now())

  results UatResult[]

  @@index([suiteId])
  @@map("uat_cases")
}

model UatRun {
  id             String    @id @default(uuid())
  suiteId        String
  suite          UatSuite  @relation(fields: [suiteId], references: [id], onDelete: Cascade)
  status         String // IN_PROGRESS | COMPLETED | ABORTED
  testedByUserId String?
  testedByUser   User?     @relation(fields: [testedByUserId], references: [id], onDelete: SetNull)
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  results UatResult[]

  @@index([suiteId])
  @@index([status])
  @@map("uat_runs")
}

model UatResult {
  id       String   @id @default(uuid())
  runId    String
  run      UatRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  caseId   String
  caseRef  UatCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  status   String // PENDING | PASS | FAIL | BLOCKED | SKIPPED
  notes    String?  @db.Text
  testedAt DateTime @default(now())

  evidences UatEvidence[]

  @@unique([runId, caseId])
  @@index([runId])
  @@map("uat_results")
}

model UatEvidence {
  id               String    @id @default(uuid())
  resultId         String
  result           UatResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  fileUrl          String
  fileName         String
  fileType         String
  fileSizeBytes    Int?
  evidenceKind     String    @default("UPLOAD") // UPLOAD | LINK
  isScrubbed       Boolean   @default(false)
  containsPhiRisk  Boolean   @default(false)
  uploadedByUserId String?
  uploadedByUser   User?     @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())

  @@index([resultId])
  @@index([containsPhiRisk])
  @@map("uat_evidences")
}

model GoLiveChecklist {
  id         String    @id @default(uuid())
  name       String
  targetDate DateTime?
  status     String // PREP | CUTOVER | POST_LIVE | COMPLETED | ABORTED
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  items ChecklistItem[]

  @@map("golive_checklists")
}

model ChecklistItem {
  id               String          @id @default(uuid())
  checklistId      String
  checklist        GoLiveChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  category         String // PRE_FLIGHT | MIGRATION | VALIDATION | SIGNOFF
  task             String
  status           String // PENDING | IN_PROGRESS | DONE | BLOCKED | SKIPPED
  notes            String?         @db.Text
  assignedToUserId String?
  assignedToUser   User?           @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)
  updatedAt        DateTime        @updatedAt

  @@index([checklistId])
  @@index([category])
  @@map("golive_checklist_items")
}

model TrainingMaterial {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  url         String?
  roleTarget  String? // DOCTOR, TECHNICIAN, etc or null for ALL
  isRequired  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments TrainingAssignment[]

  @@map("training_materials")
}

model TrainingAssignment {
  id               String           @id @default(uuid())
  materialId       String
  material         TrainingMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  userId           String
  user             User             @relation("TrainingAssignedTo", fields: [userId], references: [id], onDelete: Cascade)
  status           String // PENDING | IN_PROGRESS | COMPLETED
  attestedAt       DateTime?
  attestedByUserId String? // Can be self or admin
  attestedByUser   User?            @relation("TrainingAttestedBy", fields: [attestedByUserId], references: [id], onDelete: SetNull)
  auditReason      String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([materialId, userId])
  @@index([userId])
  @@map("training_assignments")
}

model IncidentTicket {
  id               String    @id @default(uuid())
  // STRICT RULE: No PHI, no raw clinical data
  severity         String // SEV1 | SEV2 | SEV3 | SEV4
  status           String // OPEN | INVESTIGATING | RESOLVED | CLOSED
  module           String // e.g. VIEWER, HIS_GATEWAY, REPORTING
  contextType      String? // e.g. STUDY, REPORT, DICOM_NODE
  contextId        String?
  contextUrl       String?
  shortDesc        String    @db.Text // Scrubbed description
  reportedByUserId String?
  reportedByUser   User?     @relation("IncidentReportedBy", fields: [reportedByUserId], references: [id], onDelete: SetNull)
  assigneeUserId   String?
  assigneeUser     User?     @relation("IncidentAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  resolvedAt       DateTime?

  comments       IncidentComment[]
  changeRequests ChangeRequest[]

  @@index([status])
  @@index([severity])
  @@index([module])
  @@index([reportedByUserId])
  @@map("incident_tickets")
}

model IncidentComment {
  id              String         @id @default(uuid())
  ticketId        String
  ticket          IncidentTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content         String         @db.Text
  wasRedacted     Boolean        @default(false)
  redactionNotes  String?        @db.Text
  createdByUserId String?
  createdByUser   User?          @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())

  @@index([ticketId])
  @@map("incident_comments")
}

model ChangeRequest {
  id                 String            @id @default(uuid())
  title              String
  description        String            @db.Text
  module             String            @default("GENERAL")
  impactSummary      String?           @db.Text
  rollbackPlan       String?           @db.Text
  uatRequired        Boolean           @default(false)
  releaseNotesImpact String?           @db.Text
  status             String // REQUESTED | REVIEWING | APPROVED | REJECTED | IMPLEMENTED | CANCELLED
  riskLevel          String // LOW | MEDIUM | HIGH
  releaseId          String?
  release            ReleaseCandidate? @relation(fields: [releaseId], references: [id], onDelete: SetNull)
  uatSuiteId         String?
  uatSuite           UatSuite?         @relation(fields: [uatSuiteId], references: [id], onDelete: SetNull)
  incidentId         String?
  incident           IncidentTicket?   @relation(fields: [incidentId], references: [id], onDelete: SetNull)
  requestedByUserId  String?
  requestedByUser    User?             @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  approvals ChangeApproval[]

  @@index([status])
  @@index([releaseId])
  @@index([uatSuiteId])
  @@index([incidentId])
  @@map("change_requests")
}

model ChangeApproval {
  id             String        @id @default(uuid())
  changeId       String
  change         ChangeRequest @relation(fields: [changeId], references: [id], onDelete: Cascade)
  status         String // PENDING | APPROVED | REJECTED
  notes          String?       @db.Text
  reviewerUserId String
  reviewerUser   User          @relation(fields: [reviewerUserId], references: [id], onDelete: Cascade)
  reviewedAt     DateTime?
  createdAt      DateTime      @default(now())

  @@unique([changeId, reviewerUserId])
  @@index([changeId])
  @@map("change_approvals")
}

model Runbook {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  category    String // DEPLOYMENT | MAINTENANCE | INCIDENT_RESPONSE
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps      RunbookStep[]
  executions RunbookExecution[]

  @@map("runbooks")
}

model RunbookStep {
  id          String  @id @default(uuid())
  runbookId   String
  runbook     Runbook @relation(fields: [runbookId], references: [id], onDelete: Cascade)
  order       Int
  title       String
  description String  @db.Text
  isRisky     Boolean @default(false)
  actionUrl   String? // Link to existing UI feature

  @@unique([runbookId, order])
  @@index([runbookId])
  @@map("runbook_steps")
}

model RunbookExecution {
  id               String    @id @default(uuid())
  runbookId        String
  runbook          Runbook   @relation(fields: [runbookId], references: [id], onDelete: Cascade)
  status           String // IN_PROGRESS | COMPLETED | FAILED | ABORTED
  executedByUserId String?
  executedByUser   User?     @relation(fields: [executedByUserId], references: [id], onDelete: SetNull)
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  logJson          String?   @db.Text // Contains confirmation audits for risky steps
  activeKey        String?   @unique // runbookId while IN_PROGRESS, null after finish

  @@index([runbookId])
  @@index([status])
  @@map("runbook_executions")
}

// ==========================================
// PHASE 11: PR 11.1 Schema Additions
// ==========================================

model SchedulerLease {
  id              String      @id @default(uuid())
  leaseKey        String      @unique
  fencingToken    Int         @default(0)
  ownerId         String
  status          String      @default("ACTIVE") // ACTIVE | EXPIRED | COMPLETED | FAILED
  expiresAt       DateTime
  lastHeartbeatAt DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  runs            WorkerRun[]

  @@index([status])
  @@index([expiresAt])
  @@map("scheduler_leases")
}

model WorkerRun {
  id             String         @id @default(uuid())
  leaseKey       String
  lease          SchedulerLease @relation(fields: [leaseKey], references: [leaseKey], onDelete: Cascade)
  fencingToken   Int
  ownerId        String
  startedAt      DateTime       @default(now())
  completedAt    DateTime?
  status         String         @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | FAILED
  processedCount Int            @default(0)
  errorCount     Int            @default(0)
  logJson        String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([leaseKey, fencingToken])
  @@index([status])
  @@index([createdAt])
  @@map("worker_runs")
}

model AlertRule {
  id                String                  @id @default(uuid())
  name              String
  ruleType          String
  isActive          Boolean                 @default(true)
  severity          String                  @default("WARNING")
  conditionJson     String                  @db.Text
  actionJson        String?                 @db.Text
  cooldownMins      Int                     @default(60)
  metadataJson      String?                 @db.Text
  thresholdPolicyId String?
  thresholdPolicy   ControlThresholdPolicy? @relation(fields: [thresholdPolicyId], references: [id], onDelete: SetNull)
  creatorId         String?
  creator           User?                   @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  scope             String?
  lastTriggeredAt   DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  events AlertEvent[]

  @@index([isActive])
  @@index([ruleType])
  @@map("alert_rules")
}

model AlertEvent {
  id                   String     @id @default(uuid())
  idempotencyKey       String     @unique
  ruleId               String?
  rule                 AlertRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  severity             String
  title                String
  message              String     @db.Text
  status               String     @default("OPEN") // OPEN | ACKNOWLEDGED | RESOLVED
  entityType           String?
  entityId             String?
  metadataJson         String?    @db.Text
  acknowledgedByUserId String?
  acknowledgedByUser   User?      @relation("AlertEventAcknowledgedBy", fields: [acknowledgedByUserId], references: [id], onDelete: SetNull)
  acknowledgedAt       DateTime?
  resolvedByUserId     String?
  resolvedByUser       User?      @relation("AlertEventResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  resolvedAt           DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([status])
  @@index([severity])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("alert_events")
}

model SlaPolicy {
  id                      String            @id @default(uuid())
  code                    String            @unique
  name                    String
  scope                   String // GLOBAL | FACILITY | MODALITY | PROCEDURE | PRIORITY | DOCTOR | ROLE | MODULE
  facilityId              String?
  facility                FacilityUnit?     @relation(fields: [facilityId], references: [id], onDelete: SetNull)
  modality                String?
  procedureCatalogId      String?
  procedureCatalog        ProcedureCatalog? @relation(fields: [procedureCatalogId], references: [id], onDelete: SetNull)
  priority                String?
  doctorId                String?
  doctor                  User?             @relation("SlaPolicyDoctor", fields: [doctorId], references: [id], onDelete: SetNull)
  role                    String?
  machineId               String?
  machine                 DicomNode?        @relation("SlaPolicyMachine", fields: [machineId], references: [id], onDelete: SetNull)
  module                  String?
  stage                   String // ORDER_TO_CHECKIN | CHECKIN_TO_SCAN | SCAN_TO_RECEIVED | RECEIVED_TO_FIRST_READ | FIRST_READ_TO_FINAL | FINAL_TO_DELIVERED | END_TO_END
  thresholdMinutes        Int
  warningThresholdMinutes Int?
  severity                String            @default("MEDIUM")
  effectiveFrom           DateTime?
  effectiveTo             DateTime?
  description             String?           @db.Text
  isActive                Boolean           @default(true)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@index([scope])
  @@index([facilityId])
  @@index([procedureCatalogId])
  @@index([doctorId])
  @@index([machineId])
  @@index([module])
  @@index([isActive])
  @@index([stage])
  @@map("sla_policies")
}

model ControlThresholdPolicy {
  id                      String    @id @default(uuid())
  code                    String    @unique
  groupKey                String // SLA_TAT | WORKFLOW_QUEUE | HIS | PACS_DICOM | STORAGE_BACKUP | EXPORT_DOWNLOAD | SHARE_CONSULT | QUALITY_SAFETY | DATA_QUALITY | PERFORMANCE_OPS | SECURITY_AUDIT
  metricKey               String
  name                    String
  description             String?   @db.Text
  scopeType               String    @default("GLOBAL") // GLOBAL | FACILITY | MODALITY | PROCEDURE | PRIORITY | MACHINE | DOCTOR | ROLE | MODULE
  scopeValue              String?
  operator                String    @default(">=")
  warningValue            Float?
  criticalValue           Float?
  unit                    String
  evaluationWindowMinutes Int?
  cooldownMinutes         Int       @default(30)
  escalationMode          String    @default("ALERT") // BADGE_ONLY | ALERT | INCIDENT_SUGGESTION
  ownerRole               String?
  playbookUrl             String?
  isActive                Boolean   @default(true)
  effectiveFrom           DateTime?
  effectiveTo             DateTime?
  createdByUserId         String?
  createdByUser           User?     @relation("ControlThresholdPolicyCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  alertRules AlertRule[]

  @@index([groupKey])
  @@index([metricKey])
  @@index([scopeType, scopeValue])
  @@index([isActive])
  @@map("control_threshold_policies")
}

// Phase 2: Scope Authorization
model AccessScopeGrant {
  id                 String    @id @default(uuid())
  userId             String?
  roleProfileId      String?
  facilityUnitId     String?
  dicomNodeId        String?
  capability         String
  effect             String // ALLOW | DENY
  includeDescendants Boolean   @default(true)
  validFrom          DateTime?
  validUntil         DateTime?
  reason             String?   @db.Text
  createdByUserId    String?
  updatedByUserId    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user         User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleProfile  AppRoleProfile? @relation(fields: [roleProfileId], references: [id], onDelete: Cascade)
  facilityUnit FacilityUnit?   @relation(fields: [facilityUnitId], references: [id], onDelete: Cascade)
  dicomNode    DicomNode?      @relation(fields: [dicomNodeId], references: [id], onDelete: Cascade)

  @@index([userId, capability, effect])
  @@index([roleProfileId, capability, effect])
  @@index([facilityUnitId, capability])
  @@index([dicomNodeId, capability])
  @@index([validFrom, validUntil])
  @@map("access_scope_grants")
}
