// Phase 7: Sharing And Consultation
// -----------------------------------------------------------------------------

model ShareLink {
  id                     String        @id @default(uuid())
  tokenHash              String        @unique
  shortCode              String?       @unique
  scope                  String // STUDY | REPORT | NON_DICOM_EXAM | MEDIA_SET | VIEWER_ARTIFACTS
  studyInstanceUid       String?
  imagingStudyId         String?
  imagingStudy           ImagingStudy? @relation(fields: [imagingStudyId], references: [id])
  reportId               String?
  report                 Report?       @relation(fields: [reportId], references: [id])
  nonDicomExamId         String?
  nonDicomExam           NonDicomExam? @relation(fields: [nonDicomExamId], references: [id])
  createdByUserId        String?
  createdByUser          User?         @relation("ShareLinksCreated", fields: [createdByUserId], references: [id])
  status                 String        @default("ACTIVE") // ACTIVE | REVOKED | EXPIRED | LOCKED
  expiresAt              DateTime
  revokedAt              DateTime?
  revokedByUserId        String?
  revokedByUser          User?         @relation("ShareLinksRevoked", fields: [revokedByUserId], references: [id])
  revokeReason           String?       @db.Text
  passwordHash           String?
  passwordRequired       Boolean       @default(false)
  failedPasswordAttempts Int           @default(0)
  lockedAt               DateTime?
  hidePatientInfo        Boolean       @default(true)
  allowDownload          Boolean       @default(false)
  allowImages            Boolean       @default(true)
  allowReport            Boolean       @default(true)
  allowMeasurements      Boolean       @default(true)
  maxAccessCount         Int?
  accessCount            Int           @default(0)
  lastAccessedAt         DateTime?
  metadataJson           String?       @db.Text
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  accessLogs      ShareAccessLog[]
  mediaSelections ShareMediaSelection[]

  @@index([tokenHash])
  @@index([shortCode])
  @@index([status])
  @@index([expiresAt])
  @@index([studyInstanceUid])
  @@index([createdByUserId])
  @@map("share_links")
}

model ShareAccessLog {
  id              String    @id @default(uuid())
  shareLinkId     String
  shareLink       ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  eventType       String // OPENED | PASSWORD_FAILED | PASSWORD_PASSED | VIEWED_REPORT | VIEWED_IMAGE | DOWNLOAD_DENIED | EXPIRED_DENIED | REVOKED_DENIED
  ipHash          String?
  userAgentHash   String?
  viewerSessionId String?
  metadataJson    String?   @db.Text
  createdAt       DateTime  @default(now())

  @@index([shareLinkId])
  @@index([eventType])
  @@index([createdAt])
  @@map("share_access_logs")
}

model ShareMediaSelection {
  id          String    @id @default(uuid())
  shareLinkId String
  shareLink   ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  mediaType   String // VIEWER_KEY_IMAGE | VIEWER_SNAPSHOT | NON_DICOM_MEDIA
  mediaId     String
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([shareLinkId])
  @@index([mediaType, mediaId])
  @@map("share_media_selections")
}

model Consultation {
  id                   String        @id @default(uuid())
  consultCode          String        @unique
  title                String
  reason               String?       @db.Text
  status               String        @default("REQUESTED") // REQUESTED | STARTED | IN_PROGRESS | FINISHED | CANCELLED
  priority             String        @default("ROUTINE") // ROUTINE | URGENT | STAT
  sourceType           String // DICOM | NON_DICOM | REPORT | ARCHIVE
  studyInstanceUid     String?
  imagingStudyId       String?
  imagingStudy         ImagingStudy? @relation(fields: [imagingStudyId], references: [id])
  reportId             String?
  report               Report?       @relation(fields: [reportId], references: [id])
  nonDicomExamId       String?
  nonDicomExam         NonDicomExam? @relation(fields: [nonDicomExamId], references: [id])
  createdByUserId      String?
  createdByUser        User?         @relation("ConsultationsCreated", fields: [createdByUserId], references: [id])
  hostUserId           String?
  hostUser             User?         @relation("ConsultationsHosted", fields: [hostUserId], references: [id])
  assignedDoctorId     String?
  assignedDoctor       User?         @relation("ConsultationsAssigned", fields: [assignedDoctorId], references: [id])
  startedAt            DateTime?
  finishedAt           DateTime?
  cancelledAt          DateTime?
  cancelReason         String?       @db.Text
  videoProvider        String?
  videoRoomId          String?
  videoJoinUrlInternal String?       @db.Text
  providerStatus       String        @default("DISABLED") // DISABLED | READY | FAILED
  metadataJson         String?       @db.Text
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  participants ConsultationParticipant[]
  messages     ConsultationMessage[]

  @@index([status])
  @@index([priority])
  @@index([studyInstanceUid])
  @@index([nonDicomExamId])
  @@index([createdByUserId])
  @@index([hostUserId])
  @@index([createdAt])
  @@map("consultations")
}

model ConsultationParticipant {
  id              String       @id @default(uuid())
  consultationId  String
  consultation    Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?        @relation("ConsultationParticipants", fields: [userId], references: [id])
  displayName     String
  role            String       @default("CONSULTANT") // HOST | CONSULTANT | OBSERVER | EXTERNAL
  status          String       @default("INVITED") // INVITED | JOINED | LEFT | REMOVED
  invitedByUserId String?
  invitedByUser   User?        @relation("ConsultationInvitations", fields: [invitedByUserId], references: [id])
  joinedAt        DateTime?
  leftAt          DateTime?
  createdAt       DateTime     @default(now())

  @@index([consultationId])
  @@index([userId])
  @@index([status])
  @@map("consultation_participants")
}

model ConsultationMessage {
  id                String       @id @default(uuid())
  consultationId    String
  consultation      Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  senderUserId      String?
  senderUser        User?        @relation("ConsultationMessages", fields: [senderUserId], references: [id])
  senderDisplayName String?
  messageType       String       @default("TEXT") // TEXT | SYSTEM
  body              String       @db.Text
  metadataJson      String?      @db.Text
  createdAt         DateTime     @default(now())

  @@index([consultationId])
  @@index([createdAt])
  @@map("consultation_messages")
}

