model DicomConformanceRunItem {
  id           String              @id @default(uuid())
  runId        String
  run          DicomConformanceRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  stepKey      String
  status       String // SUCCESS | FAILED | SKIPPED
