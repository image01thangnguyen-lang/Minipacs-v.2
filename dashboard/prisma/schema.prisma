  captureSessions NonDicomCaptureSession[]
  shareLinks      ShareLink[]
  consultations   Consultation[]

  @@index([status])
  @@index([machineId])
  @@index([assignedDoctorId])
  @@index([technologistId])
  @@index([procedureCatalogId])
  @@index([createdAt])
  @@index([accessionNumber])
  @@index([caseCode])
