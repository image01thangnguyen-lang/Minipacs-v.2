  startedAt         DateTime  @default(now())
  finishedAt        DateTime?

  items SystemHealthCheckItem[]

  @@index([status])
  @@index([startedAt])
  @@index([triggeredByUserId])
  @@map("system_health_check_runs")
}

model SystemHealthCheckItem {
  id           String               @id @default(uuid())
  runId        String
  run          SystemHealthCheckRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  checkKey     String
  category     String
  status       String // OK | WARN | FAIL | SKIPPED
  message      String?              @db.Text
  durationMs   Int?
  metadataJson String?              @db.Text
  createdAt    DateTime             @default(now())

  @@index([runId])
  @@index([checkKey])
  @@index([status])
  @@index([createdAt])
  @@map("system_health_check_items")
}

model SecurityAuditRun {
  id                String    @id @default(uuid())
  status            String // OK | WARN | FAIL
  triggeredByUserId String?
  triggeredByUser   User?     @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  startedAt         DateTime  @default(now())
  finishedAt        DateTime?

  findings SecurityAuditFinding[]

  @@index([status])
  @@index([startedAt])
  @@index([triggeredByUserId])
  @@map("security_audit_runs")
}

model SecurityAuditFinding {
  id               String            @id @default(uuid())
  runId            String?
  run              SecurityAuditRun? @relation(fields: [runId], references: [id], onDelete: Cascade)
  findingKey       String
  severity         String // P0 | P1 | P2 | P3
  status           String // OPEN | ACKNOWLEDGED | FIXED | ACCEPTED_RISK
  title            String
  description      String            @db.Text
  affectedArea     String
  recommendation   String?           @db.Text
  resolvedByUserId String?
  resolvedByUser   User?             @relation(fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  resolvedAt       DateTime?
  metadataJson     String?           @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([runId])
  @@index([findingKey])
  @@index([severity])
  @@index([status])
  @@index([resolvedByUserId])
  @@map("security_audit_findings")
}

model PerformanceTestRun {
  id                String    @id @default(uuid())
  testKey           String
  status            String // PENDING | RUNNING | SUCCESS | FAILED | CANCELLED
  triggeredByUserId String?
  triggeredByUser   User?     @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)
  durationMs        Int?
  inputJson         String?   @db.Text
  resultJson        String?   @db.Text
  errorMessage      String?   @db.Text
  createdAt         DateTime  @default(now())
  completedAt       DateTime?

  @@index([testKey])
  @@index([status])
  @@index([createdAt])
  @@index([triggeredByUserId])
  @@map("performance_test_runs")
}

model DicomConformanceRun {
  id                  String     @id @default(uuid())
  testKey             String
  dicomNodeId         String?
  dicomNode           DicomNode? @relation(fields: [dicomNodeId], references: [id], onDelete: SetNull)
  status              String // SUCCESS | FAILED | SKIPPED
