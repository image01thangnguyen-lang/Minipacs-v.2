// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportStatus {
  DRAFT
  FINAL
  UNREAD
  DRAFTING
  COMPLETED
}

enum OrderStatus {
  REQUESTED
  SCHEDULED
  ARRIVED
  CANCELLED
  EXPIRED
}

enum StudyStatus {
  ORDERED
  READY_FOR_SCAN
  IN_PROGRESS
  RECEIVED
  STABLE
  NEEDS_QC
  QC_REJECTED
  READY_TO_READ
  READING
  REPORTED
  FINALIZED
  DELIVERED
  ARCHIVED
  DELETED_FROM_PACS
  ERROR
}

model Report {
  id               String        @id @default(uuid())
  studyInstanceUid String        @unique
  status           ReportStatus  @default(DRAFT)
  imagingStudyId   String?
  imagingStudy     ImagingStudy? @relation(fields: [imagingStudyId], references: [id])

  // Rich text HTML bindings
  findings       String? @db.Text
  conclusion     String? @db.Text
  recommendation String? @db.Text

  // Foreign key for Doctor/User (1-N Relationship)
  doctorId String?
  doctor   User?            @relation("DoctorReports", fields: [doctorId], references: [id])
  addenda  ReportAddendum[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reports")
}

enum Role {
  ADMIN
  DOCTOR
  TECHNICIAN
  RECEPTION
}

model User {
  id            String          @id @default(uuid())
  username      String          @unique
  password      String
  fullName      String
  role          Role            @default(DOCTOR)
  roleProfileId String?
  roleProfile   AppRoleProfile? @relation(fields: [roleProfileId], references: [id])
  isActive      Boolean         @default(true)

  // Relation back to reports
  reports             Report[]             @relation("DoctorReports")
  doctorProfile       DoctorProfile?
  reportTemplateTexts ReportTemplateText[] @relation("ReportTemplateOwner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleProfileId])
  @@map("users")
}

model AppRoleProfile {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?  @db.Text
  baseRole    Role     @default(RECEPTION)
  permissions String[]
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([baseRole])
  @@index([isActive])
  @@map("app_role_profiles")
}

model DoctorProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title              String?
  specialty          String?
  licenseNumber      String?
  signatureImagePath String?
  isSigningDoctor    Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("doctor_profiles")
}

model PrintTemplate {
  id          String  @id @default(uuid())
  name        String
  htmlContent String  @db.Text
  isDefault   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("print_templates")
}

model ReportTemplateText {
  id             String   @id @default(uuid())
  name           String
  modality       String
  bodyPart       String?
  shortcut       String?
  findings       String   @db.Text
  conclusion     String   @db.Text
  recommendation String?  @db.Text
  isNormal       Boolean  @default(false)
  isActive       Boolean  @default(true)
  scope          String   @default("GLOBAL")
  ownerUserId    String?
  owner          User?    @relation("ReportTemplateOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([modality])
  @@index([bodyPart])
  @@index([shortcut])
  @@index([scope])
  @@index([ownerUserId])
  @@map("report_template_texts")
}

model ClinicProfile {
  id                    String   @id @default(uuid())
  name                  String
  legalName             String?
  address               String?
  phone                 String?
  email                 String?
  website               String?
  logoPath              String?
  headerText            String?  @db.Text
  footerText            String?  @db.Text
  licenseNumber         String?
  defaultReportLanguage String   @default("vi")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("clinic_profiles")
}

model WorklistOrder {
  id                        String    @id @default(uuid())
  patientName               String
  patientId                 String
  dob                       DateTime?
  gender                    String? // M, F, O
  phone                     String?
  referringPhysician        String?
  modality                  String
  bodyPart                  String?
  procedureCode             String?
  procedureDescription      String?
  priority                  String    @default("ROUTINE")
  scheduledStationAeTitle   String?
  scheduledStationName      String?
  accessionNumber           String    @unique
  requestedStudyInstanceUid String?
  scheduledDate             DateTime  @default(now())
  arrivedAt                 DateTime?
  cancelledAt               DateTime?
  notes                     String?   @db.Text
  worklistFilePath          String?

  // Legacy string status kept for compatibility with existing data.
  status      String      @default("PENDING")
  orderStatus OrderStatus @default(REQUESTED)

  imagingStudies ImagingStudy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduledDate])
  @@index([patientId])
  @@index([orderStatus])
  @@index([modality])
  @@map("worklist_orders")
}

model ImagingStudy {
  id               String         @id @default(uuid())
  studyInstanceUid String         @unique
  orthancStudyId   String?        @unique
  accessionNumber  String?
  patientId        String?
  patientName      String?
  modality         String?
  priority         String?
  stationAeTitle   String?
  assignedDoctorId String?
  bodyPart         String?
  studyDescription String?
  status           StudyStatus    @default(ORDERED)
  orderId          String?
  order            WorklistOrder? @relation(fields: [orderId], references: [id])
  reports          Report[]
  scheduledAt      DateTime?
  checkedInAt      DateTime?
  scanStartedAt    DateTime?
  scanEndedAt      DateTime?
  receivedAt       DateTime?
  stableAt         DateTime?
  qcCompletedAt    DateTime?
  firstOpenedAt    DateTime?
  finalizedAt      DateTime?
  deliveredAt      DateTime?
  archivedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  statusHistory   StudyStatusHistory[]
  events          ImagingStudyEvent[]
  qcEvents        StudyQcEvent[]
  criticalResults CriticalResult[]
  reportAddenda   ReportAddendum[]

  @@index([status])
  @@index([patientId])
  @@index([accessionNumber])
  @@index([modality])
  @@index([priority])
  @@index([stationAeTitle])
  @@index([assignedDoctorId])
  @@index([scheduledAt])
  @@index([receivedAt])
  @@index([finalizedAt])
  @@index([deliveredAt])
  @@map("imaging_studies")
}

model StudyStatusHistory {
  id             String       @id @default(uuid())
  imagingStudyId String
  imagingStudy   ImagingStudy @relation(fields: [imagingStudyId], references: [id], onDelete: Cascade)
  fromStatus     StudyStatus?
  toStatus       StudyStatus
  reason         String?
  actorUserId    String?
  source         String       @default("SYSTEM")
  metadataJson   String?      @db.Text
  createdAt      DateTime     @default(now())

  @@index([imagingStudyId])
  @@index([createdAt])
  @@map("study_status_history")
}

model ImagingStudyEvent {
  id             String       @id @default(uuid())
  imagingStudyId String
  imagingStudy   ImagingStudy @relation(fields: [imagingStudyId], references: [id], onDelete: Cascade)
  eventType      String
  fromStatus     StudyStatus?
  toStatus       StudyStatus?
  actorUserId    String?
  source         String       @default("SYSTEM")
  metadataJson   String?      @db.Text
  createdAt      DateTime     @default(now())

  @@index([imagingStudyId])
  @@index([eventType])
  @@index([createdAt])
  @@map("imaging_study_events")
}

model OperationalAlert {
  id                   String    @id @default(uuid())
  alertType            String
  severity             String    @default("warning")
  status               String    @default("OPEN")
  title                String
  message              String?   @db.Text
  entityType           String
  entityId             String?
  ruleKey              String?
  imagingStudyId       String?
  worklistOrderId      String?
  dicomNodeId          String?
  studyInstanceUid     String?
  patientName          String?
  priority             String?
  assignedToUserId     String?
  acknowledgedAt       DateTime?
  acknowledgedByUserId String?
  resolvedAt           DateTime?
  resolvedByUserId     String?
  metadataJson         String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([alertType])
  @@index([severity])
  @@index([status])
  @@index([entityType, entityId])
  @@index([ruleKey])
  @@index([imagingStudyId])
  @@index([worklistOrderId])
  @@index([dicomNodeId])
  @@index([createdAt])
  @@map("operational_alerts")
}

model PacsHealthSnapshot {
  id                      String     @id @default(uuid())
  orthancOnline           Boolean    @default(false)
  orthancVersion          String?
  dicomReceiveStatus      String?
  patients                Int        @default(0)
  studies                 Int        @default(0)
  series                  Int        @default(0)
  instances               Int        @default(0)
  storageDiskSizeMb       Int        @default(0)
  storageUncompressedMb   Int        @default(0)
  storageFreeMb           Int?
  storageGrowthMbPerDay   Int?
  storageForecastDays     Int?
  nodeId                  String?
  node                    DicomNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  nodeEchoStatus          String?
  nodeEchoMessage         String?
  lastStudyReceivedAt     DateTime?
  missingMetadataCount    Int        @default(0)
  duplicateAccessionCount Int        @default(0)
  metadataJson            String?    @db.Text
  createdAt               DateTime   @default(now())

  @@index([createdAt])
  @@index([nodeId])
  @@index([nodeEchoStatus])
  @@map("pacs_health_snapshots")
}

model StudyQcEvent {
  id             String       @id @default(uuid())
  imagingStudyId String
  imagingStudy   ImagingStudy @relation(fields: [imagingStudyId], references: [id], onDelete: Cascade)
  status         String
  reasonCode     String?
  note           String?
  actorUserId    String?
  createdAt      DateTime     @default(now())

  @@index([imagingStudyId])
  @@index([status])
  @@index([reasonCode])
  @@index([createdAt])
  @@map("study_qc_events")
}

model CriticalResult {
  id                   String       @id @default(uuid())
  imagingStudyId       String
  imagingStudy         ImagingStudy @relation(fields: [imagingStudyId], references: [id], onDelete: Cascade)
  severity             String       @default("critical")
  finding              String       @db.Text
  communicationStatus  String       @default("PENDING")
  communicatedTo       String?
  communicatedAt       DateTime?
  communicatedByUserId String?
  createdByUserId      String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([imagingStudyId])
  @@index([severity])
  @@index([communicationStatus])
  @@index([createdAt])
  @@map("critical_results")
}

model ReportAddendum {
  id             String        @id @default(uuid())
  imagingStudyId String?
  imagingStudy   ImagingStudy? @relation(fields: [imagingStudyId], references: [id], onDelete: Cascade)
  reportId       String?
  report         Report?       @relation(fields: [reportId], references: [id], onDelete: SetNull)
  doctorId       String?
  reasonCode     String?
  content        String?       @db.Text
  createdAt      DateTime      @default(now())

  @@index([imagingStudyId])
  @@index([reportId])
  @@index([doctorId])
  @@index([reasonCode])
  @@index([createdAt])
  @@map("report_addenda")
}

model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String?
  action       String
  entityType   String
  entityId     String?
  message      String?
  metadataJson String?  @db.Text
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model DicomNode {
  id              String               @id @default(uuid())
  name            String
  aeTitle         String
  ipAddress       String
  port            Int
  modality        String
  room            String?
  isActive        Boolean              @default(true)
  orthancAlias    String               @unique
  lastEchoStatus  String?
  lastEchoMessage String?
  lastEchoAt      DateTime?
  healthSnapshots PacsHealthSnapshot[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([aeTitle])
  @@map("dicom_nodes")
}
