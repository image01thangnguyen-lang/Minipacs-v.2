  metadataJson String?             @db.Text
  createdAt    DateTime            @default(now())

  @@index([runId])
  @@index([stepKey])
  @@index([status])
  @@map("dicom_conformance_run_items")
}

model NativeConnectorConfig {
  id                 String    @id @default(uuid())
