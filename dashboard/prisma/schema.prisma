// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportStatus {
  DRAFT
  PENDING_APPROVAL
  FINAL
}

enum OrderStatus {
  REQUESTED
  SCHEDULED
  ARRIVED
  CANCELLED
  EXPIRED
}

enum StudyStatus {
  ORDERED
  READY_FOR_SCAN
  IN_PROGRESS
  RECEIVED
  STABLE
  NEEDS_QC
  QC_REJECTED
  READY_TO_READ
  READING
  REPORTED
  FINALIZED
  DELIVERED
  ARCHIVED
  DELETED_FROM_PACS
  ERROR
}

model Report {
  id               String        @id @default(uuid())
  studyInstanceUid String        @unique
  status           ReportStatus  @default(DRAFT)
  imagingStudyId   String?
  imagingStudy     ImagingStudy? @relation(fields: [imagingStudyId], references: [id])

  // Rich text HTML bindings
  findings       String? @db.Text
  conclusion     String? @db.Text
  recommendation String? @db.Text

  // Phase 1: additional clinical fields
  technique       String? @db.Text
  clinicalInfo    String? @db.Text
  technologistId  String?
  printTemplateId String?

  // Phase 1: lifecycle timestamps and reasons
  finalizedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?   @db.Text
  reopenReason String?   @db.Text

  // Foreign key for Doctor/User (1-N Relationship)
  doctorId String?
  doctor   User?            @relation("DoctorReports", fields: [doctorId], references: [id])
  addenda  ReportAddendum[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Phase 2 HIS Integration
  hisResultStatus    String?
  hisResultSentAt    DateTime?
  hisResultMessageId String?
  hisResultError     String?

  // Phase 7
  shareLinks    ShareLink[]
  consultations Consultation[]

  @@map("reports")
}

enum Role {
  ADMIN
  DOCTOR
  TECHNICIAN
  RECEPTION
}

model User {
  id            String          @id @default(uuid())
  username      String          @unique
  password      String
  fullName      String
  role          Role            @default(DOCTOR)
  roleProfileId String?
  roleProfile   AppRoleProfile? @relation(fields: [roleProfileId], references: [id])
  isActive      Boolean         @default(true)

  // Relation back to reports
  reports                       Report[]                    @relation("DoctorReports")
  doctorProfile                 DoctorProfile?
  auditLogs                     AuditLog[]
  reportTemplateTexts           ReportTemplateText[]        @relation("ReportTemplateOwner")
  machinePermissions            DoctorMachinePermission[]
  viewerUserPreference          ViewerUserPreference?
  viewerDownloadJobs            ViewerDownloadJob[]         @relation("ViewerDownloadJobUser")
  viewerActionRequestsRequested ViewerSeriesActionRequest[] @relation("ViewerActionRequestsRequested")
  viewerActionRequestsApproved  ViewerSeriesActionRequest[] @relation("ViewerActionRequestsApproved")
  viewerAuditLogs               ViewerAuditLog[]            @relation("ViewerAuditLogActor")

  // Phase 7
  shareLinksCreated        ShareLink[]               @relation("ShareLinksCreated")
  shareLinksRevoked        ShareLink[]               @relation("ShareLinksRevoked")
  consultationsCreated     Consultation[]            @relation("ConsultationsCreated")
  consultationsHosted      Consultation[]            @relation("ConsultationsHosted")
  consultationsAssigned    Consultation[]            @relation("ConsultationsAssigned")
  consultationParticipants ConsultationParticipant[] @relation("ConsultationParticipants")
  consultationInvitations  ConsultationParticipant[] @relation("ConsultationInvitations")
  consultationMessages     ConsultationMessage[]     @relation("ConsultationMessages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleProfileId])
  @@map("users")
}

model AppRoleProfile {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String?  @db.Text
  baseRole    Role     @default(RECEPTION)
  permissions String[]
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([baseRole])
  @@index([isActive])
  @@map("app_role_profiles")
}

model DoctorProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title              String?
  specialty          String?
  licenseNumber      String?
  signatureImagePath String?
  isSigningDoctor    Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("doctor_profiles")
}

model PrintTemplate {
  id          String  @id @default(uuid())
  name        String
  htmlContent String  @db.Text
  isDefault   Boolean @default(false)

  // Phase 3 additions
  code               String?           @unique
  description        String?
  modality           String?
  bodyPart           String?
  facilityId         String?
  facility           FacilityUnit?     @relation(fields: [facilityId], references: [id])
  procedureCatalogId String?
  procedure          ProcedureCatalog? @relation(fields: [procedureCatalogId], references: [id])
  dicomNodeId        String?
  dicomNode          DicomNode?        @relation(fields: [dicomNodeId], references: [id])
  paperSize          String?
  orientation        String?
  isActive           Boolean           @default(true)
  sortOrder          Int               @default(0)
  metadataJson       String?           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  defaultForNodes DicomNode[] @relation("NodeDefaultPrintTemplate")

  @@index([dicomNodeId])
  @@index([procedureCatalogId])
  @@index([facilityId])
  @@map("print_templates")
}

model ReportTemplateText {
  id             String   @id @default(uuid())
  name           String
  modality       String
  bodyPart       String?
  shortcut       String?
  findings       String   @db.Text
  conclusion     String   @db.Text
  recommendation String?  @db.Text
  isNormal       Boolean  @default(false)
  isActive       Boolean  @default(true)
  scope          String   @default("GLOBAL")
  ownerUserId    String?
  owner          User?    @relation("ReportTemplateOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  procedureMappings ProcedureReportTemplateMapping[]
  defaultForNodes   DicomNode[]                      @relation("NodeDefaultReportTemplate")

  @@index([modality])
  @@index([bodyPart])
  @@index([shortcut])
  @@index([scope])
  @@index([ownerUserId])
  @@map("report_template_texts")
}

model ClinicProfile {
  id                    String   @id @default(uuid())
  name                  String
  legalName             String?
  address               String?
  phone                 String?
  email                 String?
  website               String?
  logoPath              String?
  faviconPath           String?
  headerText            String?  @db.Text
  footerText            String?  @db.Text
  licenseNumber         String?
  defaultReportLanguage String   @default("vi")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("clinic_profiles")
}

model WorklistOrder {
  id                        String    @id @default(uuid())
  patientName               String
  patientId                 String
  dob                       DateTime?
  gender                    String? // M, F, O
  phone                     String?
  referringPhysician        String?
  referringDepartment       String?
  sourceFacility            String?
  modality                  String
  bodyPart                  String?
  procedureCode             String?
  procedureDescription      String?
  price                     Decimal?  @db.Decimal(12, 2)
  paymentStatus             String?
  priority                  String    @default("ROUTINE")
  scheduledStationAeTitle   String?
  scheduledStationName      String?
  accessionNumber           String    @unique
  requestedStudyInstanceUid String?
  scheduledDate             DateTime  @default(now())
  arrivedAt                 DateTime?
  cancelledAt               DateTime?
  notes                     String?   @db.Text
  worklistFilePath          String?

  // Legacy string status kept for compatibility with existing data.
  status      String      @default("PENDING")
  orderStatus OrderStatus @default(REQUESTED)

  imagingStudies ImagingStudy[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  // Phase 2 HIS Integration
  hisOrderId        String?
  hisPatientId      String?
  hisVisitId        String?
  hisDepartmentCode String?
  hisSyncStatus     String?
  hisLastSyncedAt   DateTime?
  hisLastError      String?
  hisPayloadJson    String?   @db.Text

  @@index([scheduledDate])
  @@index([patientId])
  @@index([orderStatus])
  @@index([modality])
  @@index([referringPhysician])
  @@index([referringDepartment])
  @@index([sourceFacility])
  @@index([procedureCode])
  @@index([paymentStatus])
  @@map("worklist_orders")
}

model ImagingStudy {
  id               String         @id @default(uuid())
  studyInstanceUid String         @unique
  orthancStudyId   String?        @unique
  accessionNumber  String?
  patientId        String?
  patientName      String?
  modality         String?
  priority         String?
  stationAeTitle   String?
  assignedDoctorId String?
  bodyPart         String?
  studyDescription String?
  status           StudyStatus    @default(ORDERED)
  orderId          String?
  order            WorklistOrder? @relation(fields: [orderId], references: [id])
  reports          Report[]

  // Phase 1: clinical/procedure fields
  clinicalInfo         String? @db.Text
  procedureCode        String?
  procedureDescription String?
  technologistId       String?

  scheduledAt   DateTime?
  checkedInAt   DateTime?
  scanStartedAt DateTime?
  scanEndedAt   DateTime?
  receivedAt    DateTime?
  stableAt      DateTime?
  qcCompletedAt DateTime?
  firstOpenedAt DateTime?
  finalizedAt   DateTime?
  deliveredAt   DateTime?
  archivedAt    DateTime?

  // Phase 6 Non-DICOM extensions
  sourceType         String?       @default("DICOM") // DICOM | NON_DICOM
  isNonDicom         Boolean       @default(false)
  mediaCount         Int           @default(0)
  videoCount         Int           @default(0)
  attachmentCount    Int           @default(0)
  primaryMediaId     String?
  captureStartedAt   DateTime?
  captureCompletedAt DateTime?
  captureStatus      String? // PENDING | CAPTURING | COMPLETED | CANCELLED
  nonDicomExam       NonDicomExam?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusHistory             StudyStatusHistory[]
  events                    ImagingStudyEvent[]
  qcEvents                  StudyQcEvent[]
  criticalResults           CriticalResult[]
  reportAddenda             ReportAddendum[]
  doseObservations          DoseObservation[]
  // Phase 2 HIS Integration
  hisOrderId                String?
  hisSyncStatus             String?
  hisResultStatus           String?
  hisLastSyncedAt           DateTime?
  hisLastResultSentAt       DateTime?
  hisLastError              String?
  ViewerSnapshot            ViewerSnapshot[]
  ViewerKeyImage            ViewerKeyImage[]
  ViewerAuditLog            ViewerAuditLog[]
  ViewerDownloadJob         ViewerDownloadJob[]
  ViewerSeriesActionRequest ViewerSeriesActionRequest[]

  // Phase 7
  shareLinks    ShareLink[]
  consultations Consultation[]

  @@index([status])
  @@index([patientId])
  @@index([accessionNumber])
  @@index([modality])
  @@index([priority])
  @@index([stationAeTitle])
  @@index([assignedDoctorId])
  @@index([scheduledAt])
  @@index([scanStartedAt])
  @@index([scanEndedAt])
  @@index([receivedAt])
  @@index([stableAt])
  @@index([qcCompletedAt])
  @@index([firstOpenedAt])
  @@index([finalizedAt])
  @@index([deliveredAt])
  @@map("imaging_studies")
}

model StudyStatusHistory {
  id             String       @id @default(uuid())
  imagingStudyId String
  imagingStudy   ImagingStudy @relation(fields: [imagingStudyId], references: [id], onDelete: Cascade)
  fromStatus     StudyStatus?
  toStatus       StudyStatus
  reason         String?
  actorUserId    String?
  source         String       @default("SYSTEM")
  metadataJson   String?      @db.Text
  createdAt      DateTime     @default(now())

  @@index([imagingStudyId])
  @@index([createdAt])
  @@map("study_status_history")
}

model ImagingStudyEvent {
  id             String       @id @default(uuid())
  imagingStudyId String
  imagingStudy   ImagingStudy @relation(fields: [imagingStudyId], references: [id], onDelete: Cascade)
  eventType      String
  fromStatus     StudyStatus?
  toStatus       StudyStatus?
  actorUserId    String?
  source         String       @default("SYSTEM")
  metadataJson   String?      @db.Text
  createdAt      DateTime     @default(now())

  @@index([imagingStudyId])
  @@index([eventType])
  @@index([createdAt])
  @@map("imaging_study_events")
}

model OperationalAlert {
  id                   String    @id @default(uuid())
  alertType            String
  severity             String    @default("warning")
  status               String    @default("OPEN")
  title                String
  message              String?   @db.Text
  entityType           String
  entityId             String?
  ruleKey              String?
  imagingStudyId       String?
  worklistOrderId      String?
  dicomNodeId          String?
  studyInstanceUid     String?
  patientName          String?
  priority             String?
  assignedToUserId     String?
  acknowledgedAt       DateTime?
  acknowledgedByUserId String?
  resolvedAt           DateTime?
  resolvedByUserId     String?
  metadataJson         String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([alertType])
  @@index([severity])
  @@index([status])
  @@index([entityType, entityId])
  @@index([ruleKey])
  @@index([imagingStudyId])
  @@index([worklistOrderId])
  @@index([dicomNodeId])
  @@index([createdAt])
  @@map("operational_alerts")
}

model PacsHealthSnapshot {
  id                      String     @id @default(uuid())
  orthancOnline           Boolean    @default(false)
  orthancVersion          String?
  dicomReceiveStatus      String?
  patients                Int        @default(0)
  studies                 Int        @default(0)
  series                  Int        @default(0)
  instances               Int        @default(0)
  storageDiskSizeMb       Int        @default(0)
  storageUncompressedMb   Int        @default(0)
  storageFreeMb           Int?
  storageGrowthMbPerDay   Int?
  storageForecastDays     Int?
  nodeId                  String?
  node                    DicomNode? @relation(fields: [nodeId], references: [id], onDelete: SetNull)
  nodeEchoStatus          String?
  nodeEchoMessage         String?
  lastStudyReceivedAt     DateTime?
  missingMetadataCount    Int        @default(0)
  duplicateAccessionCount Int        @default(0)
  metadataJson            String?    @db.Text
  createdAt               DateTime   @default(now())

  @@index([createdAt])
  @@index([nodeId])
  @@index([nodeEchoStatus])
  @@map("pacs_health_snapshots")
}

model StudyQcEvent {
  id             String       @id @default(uuid())
  imagingStudyId String
  imagingStudy   ImagingStudy @relation(fields: [imagingStudyId], references: [id], onDelete: Cascade)
  status         String
  reasonCode     String?
  note           String?
  actorUserId    String?
  createdAt      DateTime     @default(now())

  @@index([imagingStudyId])
  @@index([status])
  @@index([reasonCode])
  @@index([createdAt])
  @@map("study_qc_events")
}

model CriticalResult {
  id                   String       @id @default(uuid())
  imagingStudyId       String
  imagingStudy         ImagingStudy @relation(fields: [imagingStudyId], references: [id], onDelete: Cascade)
  severity             String       @default("critical")
  finding              String       @db.Text
  communicationStatus  String       @default("PENDING")
  communicatedTo       String?
  communicatedAt       DateTime?
  communicatedByUserId String?
  createdByUserId      String?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([imagingStudyId])
  @@index([severity])
  @@index([communicationStatus])
  @@index([createdAt])
  @@map("critical_results")
}

model ReportAddendum {
  id             String        @id @default(uuid())
  imagingStudyId String?
  imagingStudy   ImagingStudy? @relation(fields: [imagingStudyId], references: [id], onDelete: Cascade)
  reportId       String?
  report         Report?       @relation(fields: [reportId], references: [id], onDelete: SetNull)
  doctorId       String?
  reasonCode     String?
  reason         String?       @db.Text
  content        String?       @db.Text
  createdAt      DateTime      @default(now())

  @@index([imagingStudyId])
  @@index([reportId])
  @@index([doctorId])
  @@index([reasonCode])
  @@index([createdAt])
  @@map("report_addenda")
}

model DoseObservation {
  id                String       @id @default(uuid())
  imagingStudyId    String
  imagingStudy      ImagingStudy @relation(fields: [imagingStudyId], references: [id], onDelete: Cascade)
  metricType        String
  value             Float
  unit              String?
  source            String       @default("DICOM")
  seriesInstanceUid String?
  sopInstanceUid    String?
  metadataJson      String?      @db.Text
  createdAt         DateTime     @default(now())

  @@index([imagingStudyId])
  @@index([metricType])
  @@index([createdAt])
  @@map("dose_observations")
}

model ProcedureCatalog {
  id           String   @id @default(uuid())
  code         String   @unique
  name         String
  modality     String?
  bodyPart     String?
  defaultPrice Decimal? @db.Decimal(12, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Phase 3 additions
  serviceTypeId          String?
  serviceType            ServiceTypeCatalog? @relation(fields: [serviceTypeId], references: [id])
  description            String?
  defaultDurationMinutes Int?
  defaultPriority        String?
  defaultRoom            String?
  hisCode                String?
  insuranceCode          String?
  requiresContrast       Boolean             @default(false)
  isNonDicomEligible     Boolean             @default(false)
  sortOrder              Int                 @default(0)

  icdMappings            ProcedureIcdMapping[]
  reportTemplateMappings ProcedureReportTemplateMapping[]
  machineMappings        MachineProcedureMapping[]
  defaultForNodes        DicomNode[]                      @relation("NodeDefaultProcedure")
  printTemplates         PrintTemplate[]

  @@index([serviceTypeId])
  @@index([modality])
  @@index([isActive])
  @@index([hisCode])
  @@index([insuranceCode])
  @@index([modality, bodyPart])
  @@map("procedure_catalog")
}

model DashboardFilterPreset {
  id          String   @id @default(uuid())
  userId      String?
  name        String
  dashboard   String   @default("statistics")
  filtersJson String   @db.Text
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([dashboard])
  @@index([isShared])
  @@map("dashboard_filter_presets")
}

model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String?
  action       String
  entityType   String
  entityId     String?
  message      String?
  metadataJson String?  @db.Text
  ipAddress    String?
  createdAt    DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model DicomNode {
  id              String               @id @default(uuid())
  name            String
  aeTitle         String
  ipAddress       String
  port            Int
  modality        String
  room            String?
  isActive        Boolean              @default(true)
  orthancAlias    String               @unique
  lastEchoStatus  String?
  lastEchoMessage String?
  lastEchoAt      DateTime?
  healthSnapshots PacsHealthSnapshot[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Phase 3 additions
  facilityId                  String?
  facility                    FacilityUnit?        @relation(fields: [facilityId], references: [id])
  defaultFolderId             String?
  defaultFolder               StorageFolderConfig? @relation("NodeDefaultFolder", fields: [defaultFolderId], references: [id], onDelete: SetNull)
  defaultShareFolderId        String?
  defaultShareFolder          StorageFolderConfig? @relation("NodeDefaultShareFolder", fields: [defaultShareFolderId], references: [id], onDelete: SetNull)
  defaultUploadFolderId       String?
  defaultUploadFolder         StorageFolderConfig? @relation("NodeDefaultUploadFolder", fields: [defaultUploadFolderId], references: [id], onDelete: SetNull)
  defaultProcedureCatalogId   String?
  defaultProcedure            ProcedureCatalog?    @relation("NodeDefaultProcedure", fields: [defaultProcedureCatalogId], references: [id])
  defaultPrintTemplateId      String?
  defaultPrintTemplate        PrintTemplate?       @relation("NodeDefaultPrintTemplate", fields: [defaultPrintTemplateId], references: [id])
  defaultReportTemplateTextId String?
  defaultReportTemplate       ReportTemplateText?  @relation("NodeDefaultReportTemplate", fields: [defaultReportTemplateTextId], references: [id])
  serviceTypeId               String?
  serviceType                 ServiceTypeCatalog?  @relation(fields: [serviceTypeId], references: [id])
  isNonDicom                  Boolean              @default(false)
  metadataJson                String?              @db.Text

  machineMappings        MachineProcedureMapping[]
  doctorPermissions      DoctorMachinePermission[]
  reportTemplateMappings ProcedureReportTemplateMapping[]
  printTemplates         PrintTemplate[]

  @@index([facilityId])
  @@index([defaultFolderId])
  @@index([defaultShareFolderId])
  @@index([defaultUploadFolderId])
  @@index([serviceTypeId])
  @@index([aeTitle])
  @@map("dicom_nodes")
}

model ViewerSnapshot {
  id                    String       @id @default(uuid())
  studyInstanceUid      String
  study                 ImagingStudy @relation(fields: [studyInstanceUid], references: [studyInstanceUid], onDelete: Cascade)
  seriesInstanceUid     String?
  sopInstanceUid        String?
  frameNumber           Int?
  imageIndex            Int?
  imageCount            Int?
  modality              String?
  bodyPartExamined      String?
  seriesDescription     String?
  viewportState         String?      @db.Text
  windowWidth           Float?
  windowCenter          Float?
  zoom                  Float?
  displaySetInstanceUID String?
  note                  String?      @db.Text
  imageUrl              String?      @db.Text
  thumbnailUrl          String?      @db.Text
  storageKey            String?
  category              String?
  sourceType            String?
  cropRectJson          String?      @db.Text
  cropRatio             Float?
  isFullViewport        Boolean      @default(false)
  includeOverlay        Boolean      @default(true)
  isAnonymized          Boolean      @default(false)
  metadataJson          String?      @db.Text
  createdByUserId       String?
  createdAt             DateTime     @default(now())

  @@index([studyInstanceUid])
  @@index([createdAt])
  @@map("viewer_snapshots")
}

model ViewerKeyImage {
  id                    String       @id @default(uuid())
  studyInstanceUid      String
  study                 ImagingStudy @relation(fields: [studyInstanceUid], references: [studyInstanceUid], onDelete: Cascade)
  seriesInstanceUid     String?
  sopInstanceUid        String?
  frameNumber           Int?
  imageIndex            Int?
  imageCount            Int?
  modality              String?
  bodyPartExamined      String?
  seriesDescription     String?
  viewportState         String?      @db.Text
  windowWidth           Float?
  windowCenter          Float?
  zoom                  Float?
  displaySetInstanceUID String?
  note                  String?      @db.Text
  thumbnailUrl          String?      @db.Text
  storageKey            String?
  category              String?
  cropRectJson          String?      @db.Text
  cropRatio             Float?
  isSelectedForReport   Boolean      @default(false)
  isAnonymized          Boolean      @default(false)
  metadataJson          String?      @db.Text
  createdByUserId       String?
  createdAt             DateTime     @default(now())

  @@index([studyInstanceUid])
  @@index([createdAt])
  @@map("viewer_key_images")
}

model ViewerAuditLog {
  id               String       @id @default(uuid())
  studyInstanceUid String
  study            ImagingStudy @relation(fields: [studyInstanceUid], references: [studyInstanceUid], onDelete: Cascade)
  action           String
  metadataJson     String?      @db.Text
  actorUserId      String?
  actorUser        User?        @relation("ViewerAuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())

  @@index([studyInstanceUid])
  @@index([action])
  @@index([createdAt])
  @@map("viewer_audit_logs")
}

model ViewerMeasurement {
  id                    String  @id @default(uuid())
  studyInstanceUid      String
  seriesInstanceUid     String?
  sopInstanceUid        String?
  frameNumber           Int?
  displaySetInstanceUID String?
  viewportId            String?

  toolName        String
  measurementType String?
  annotationUID   String?
  measurementUID  String
  label           String?
  displayText     String? @db.Text
  value           Float?
  unit            String?

  dataJson        String    @db.Text
  isDeleted       Boolean   @default(false)
  createdByUserId String?
  updatedByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@unique([studyInstanceUid, measurementUID])
  @@index([studyInstanceUid])
  @@index([seriesInstanceUid])
  @@index([sopInstanceUid])
  @@index([toolName])
  @@index([createdAt])
  @@map("viewer_measurements")
}

model ServiceTypeCatalog {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  description     String?
  defaultModality String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  procedures ProcedureCatalog[]
  dicomNodes DicomNode[]

  @@map("service_type_catalog")
}

model IcdCatalog {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
