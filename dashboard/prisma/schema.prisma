  caseCode           String        @unique
  imagingStudyId     String?       @unique
  imagingStudy       ImagingStudy? @relation(fields: [imagingStudyId], references: [id])
  studyInstanceUid   String?
  worklistOrderId    String?       @unique
  patientId          String?
  patientName        String?
  patientBirthDate   DateTime?
  patientSex         String?
  accessionNumber    String?
  status             String        @default("REQUESTED") // REQUESTED | ARRIVED | CAPTURING | READY_TO_READ | READING | REPORTED | DELIVERED | CANCELLED
  facilityId         String?
  machineId          String?
  procedureCatalogId String?
  serviceTypeId      String?
  assignedDoctorId   String?
  technologistId     String?
  clinicalInfo       String?       @db.Text
  indication         String?       @db.Text
  captureStartedAt   DateTime?
  captureCompletedAt DateTime?
  createdByUserId    String?
  updatedByUserId    String?
  cancelledAt        DateTime?
  cancelReason       String?       @db.Text
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

